# =======================================================
# NVOIN AI AGENT CODE - ENVIRONMENT VARIABLES EXAMPLE
# Salin berkas ini menjadi .env dan sesuaikan nilainya.
# =======================================================

# 1. Konfigurasi Backend LLM (Pilih salah satu atau sesuai setup)
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:12b
LLM_BASE_URL=http://localhost:11434

# Alternatif jika menggunakan OpenAI-compatible API / vLLM
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1

# 2. Konfigurasi Workspace AI Agent
WORKSPACE_DIR=./workspace
MAX_LOOPS=8
VERBOSE=true

# 3. Konfigurasi Server API Bridge (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
