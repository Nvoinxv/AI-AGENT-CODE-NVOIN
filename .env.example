# =======================================================
# NVOIN AI AGENT CODE - ENVIRONMENT VARIABLES EXAMPLE
# Salin berkas ini menjadi .env dan sesuaikan nilainya.
# =======================================================

# 1. Konfigurasi Backend Cloud LLM API (Pilih salah satu: gemini / huggingface / qwen)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash

# API Keys untuk masing-masing penyedia Cloud LLM
GEMINI_API_KEY=your-gemini-api-key-here
HUGGING_FACE_API_KEY=your-huggingface-api-key-here
QWEN_MODEL_API=your-qwen-api-key-here

# 2. Konfigurasi Database & API Keys (PostgreSQL & MongoDB Cloud / Supabase / Atlas)
POSTGRES_URI=postgresql://nvoin_admin:nvoin_secret_password@localhost:5432/nvoin_db
POSTGRES_API_KEY=your_postgres_cloud_api_key_here
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=nvoin_chat_db
MONGODB_API_KEY=your_mongodb_atlas_api_key_here

# 3. Konfigurasi Workspace AI Agent
WORKSPACE_DIR=./workspace
MAX_LOOPS=8
VERBOSE=true

# 4. Konfigurasi Server API Bridge (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
